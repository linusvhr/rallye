{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/signup",
      "dest": "/public/signup.html"
    },
    {
      "src": "/tutorial",
      "dest": "/public/tutorial.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/signup.py"
    }
  ]
}
